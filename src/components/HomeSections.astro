---
import ServiceGrid from "./ServiceGrid.astro";
import { pageText, routes, type Locale } from "../data/site";
import { projectGroups } from "../data/projects";
import { companyStartDate, fullYearsSince } from "../utils/years";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const text = pageText[locale].home;
const nav = routes[locale];
const yearsInOperation = fullYearsSince(companyStartDate);
const projectCount = projectGroups.reduce((sum, group) => sum + group.entries.length, 0);
---

<section class="hero">
  <div class="hero-media" aria-hidden="true"></div>
  <div class="hero-content">
    <p>{text.kicker}</p>
    <h1>{text.title}</h1>
    <h2>{text.headline}</h2>
    <span>{text.subhead}</span>
    <div class="hero-actions">
      <a class="button button-primary" href={nav.projects}>{text.primaryCta}</a>
      <a class="button button-secondary" href={nav.contact}>{text.secondaryCta}</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner narrow intro-section">
    <div>
      <p class="eyebrow">{text.aboutTitle}</p>
      <h2>{text.aboutBody}</h2>
      <div class="value-grid">
        {text.values.map((value) => <span>{value}</span>)}
      </div>
    </div>
  </div>
</section>

<section class="section section-muted">
  <div class="section-inner">
    <ServiceGrid locale={locale} />
  </div>
</section>

<section class="stats-band">
  <div class="section-inner stats-grid">
    {text.stats.map((stat) => (
      <div>
        {stat.value === "projectCount" ? (
          <strong>{projectCount}+</strong>
        ) : stat.value === "yearsInOperation" ? (
          <strong data-years-since={companyStartDate}>{yearsInOperation}</strong>
        ) : (
          <strong>{stat.value}</strong>
        )}
        <span>{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  document.querySelectorAll("[data-years-since]").forEach((element) => {
    const startValue = element.getAttribute("data-years-since");
    if (!startValue) return;

    const start = new Date(`${startValue}T00:00:00`);
    const now = new Date();
    let years = now.getFullYear() - start.getFullYear();
    const anniversaryThisYear = new Date(now.getFullYear(), start.getMonth(), start.getDate());

    if (now < anniversaryThisYear) {
      years -= 1;
    }

    element.textContent = String(Math.max(0, years));
  });
</script>
