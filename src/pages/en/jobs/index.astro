---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import { company, pageText, routes } from "../../../data/site";

const locale = "en";
const text = pageText[locale].jobs;
---

<BaseLayout
  locale={locale}
  title={text.seoTitle}
  description={text.description}
  canonicalPath={routes.en.jobs}
  alternatePath={routes.et.jobs}
>
  <PageHeader title={text.title} description={text.description} />
  <section class="section">
    <div class="section-inner narrow copy-block">
      <h2>{text.heading}</h2>
      <p>{text.body}</p>
      <div class="hero-actions">
        <a class="button button-primary" href={`mailto:${company.email}`}>{text.emailCta}</a>
        <a class="text-link" href={routes.en.contact}>{text.contactCta}</a>
      </div>
    </div>
  </section>
</BaseLayout>
