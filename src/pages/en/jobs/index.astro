---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import { routes } from "../../../data/site";

const locale = "en";

const openings = [
  {
    title: "Ventilation Installer",
    location: "Harju County",
    workload: "Full-time",
    closedAt: "31 Dec 2024",
    summary:
      "We were looking for an installer to assemble and configure ventilation systems on construction sites across Estonia.",
  },
  {
    title: "Assistant to Project Manager",
    location: "Lagedi, Harju County",
    workload: "Full-time",
    closedAt: "30 Sep 2024",
    summary:
      "We were looking for an assistant to help coordinate schedules, material orders, and communication for active sites.",
  },
];
---

<BaseLayout
  locale={locale}
  title="Jobs - VAP Ventilatsioon"
  description="Past job offers from VAP Ventilatsioon."
  canonicalPath={routes.en.jobs}
  alternatePath={routes.et.jobs}
>
  <PageHeader
    title="Jobs"
    description="Below are previous VAP Ventilatsioon job listings. There are currently no active vacancies."
  />

  <section class="jobs" aria-label="Expired job listings">
    <h2>Expired job listings</h2>
    <div class="job-list">
      {openings.map((job) => (
        <article class="job-card">
          <div class="job-card__top">
            <h3>{job.title}</h3>
            <span class="job-card__status">Expired</span>
          </div>
          <p class="job-card__summary">{job.summary}</p>
          <dl class="job-card__meta">
            <div><dt>Location</dt><dd>{job.location}</dd></div>
            <div><dt>Workload</dt><dd>{job.workload}</dd></div>
            <div><dt>Application deadline</dt><dd>{job.closedAt}</dd></div>
          </dl>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .jobs { width: min(960px, 92vw); margin: 0 auto 5rem; }
  .jobs h2 { margin: 0 0 1.25rem; font-size: clamp(1.5rem, 2vw, 1.9rem); }
  .job-list { display: grid; gap: 1rem; }
  .job-card { border: 1px solid color-mix(in srgb, var(--border-color) 85%, #fff 15%); border-radius: 16px; padding: 1.2rem; background: #fff; box-shadow: 0 8px 20px rgba(7, 33, 63, 0.06); }
  .job-card__top { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.7rem; }
  .job-card__top h3 { margin: 0; font-size: clamp(1.15rem, 1.5vw, 1.35rem); }
  .job-card__status { display: inline-flex; align-items: center; border-radius: 999px; background: #f3f4f6; color: #3f4855; border: 1px solid #d5d8dd; padding: 0.25rem 0.65rem; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
  .job-card__summary { margin: 0 0 1rem; color: var(--text-muted); }
  .job-card__meta { margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 0.8rem; }
  .job-card__meta dt { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.25rem; }
  .job-card__meta dd { margin: 0; font-weight: 600; color: var(--text-color); }
</style>
