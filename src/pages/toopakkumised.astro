---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { company, routes } from "../data/site";

const locale = "et";
---

<BaseLayout
  locale={locale}
  title="Tööpakkumised - VAP Ventilatsioon"
  description="VAP Ventilatsioon OÜ tööpakkumised."
  canonicalPath={routes.et.jobs}
  alternatePath={routes.en.jobs}
>
  <PageHeader title="Tööpakkumised" description="VAP Ventilatsioon OÜ tööpakkumised." />

  <section class="jobs" aria-label="Tööpakkumised">
    <article class="job-card">
      <h2>VENTILATSIOONISÜSTEEMIDE PAIGALDAJA</h2>
      <table>
        <tbody>
          <tr>
            <th scope="row">Pakutav töökoht</th>
            <td><strong>VENTILATSIOONISÜSTEEMIDE PAIGALDAJA</strong></td>
          </tr>
          <tr>
            <th scope="row">Tööpakkumine aegub</th>
            <td><strong>Lõppenud</strong></td>
          </tr>
          <tr>
            <th scope="row">Positsioon</th>
            <td>oskustööline</td>
          </tr>
          <tr>
            <th scope="row">Töökoht asub</th>
            <td>Harjumaa, Tallinn, Eesti</td>
          </tr>
          <tr>
            <th scope="row">Töökoha kirjeldus</th>
            <td>
              Ventilatsioonisüsteemide paigaldamise (vajadusel isoleerimine) teostamine
              tööandja ehitusobjektidel Tallinnas ja mujal Eestis ning vajadusel välismaal.
            </td>
          </tr>
          <tr>
            <th scope="row">Nõuded kandidaadile</th>
            <td>
              <p>Kandidaadilt ootame</p>
              <ul>
                <li>Iseseisvust</li>
                <li>Vastutustunnet</li>
                <li>Otsustusvõimet</li>
              </ul>
              <p>Kasuks tuleb</p>
              <ul>
                <li>Eelnev töökogemus</li>
                <li>Projektilugemisoskus</li>
                <li>Autojuhilubade olemasolu</li>
                <li>Vene keele oskus</li>
              </ul>
            </td>
          </tr>
          <tr>
            <th scope="row">Nõutav haridus</th>
            <td>täpsustamata</td>
          </tr>
          <tr>
            <th scope="row">Keeleoskus</th>
            <td>eesti</td>
          </tr>
          <tr>
            <th scope="row">Juhiload</th>
            <td>B</td>
          </tr>
          <tr>
            <th scope="row">Muu info</th>
            <td>
              <p>Omalt poolt pakume</p>
              <ul>
                <li>Võimalust töötada nooruslikus ja positiivses meeskonnas</li>
                <li>Konkurentsivõimelist palka töölepingu alusel kokkulepitud päeval</li>
                <li>Mitmekülgset tööd ja arenemisvõimalusi</li>
                <li>Väljaõpet koha peal</li>
                <li>Tööks vajalikke vahendeid (tööriistad ja rõivad)</li>
                <li>Kokkuleppel transpordi võimalus</li>
              </ul>
            </td>
          </tr>
          <tr>
            <th scope="row">Pakutav tööliik ja kuupalk</th>
            <td>kokkuleppel</td>
          </tr>
          <tr>
            <th scope="row">Tööaeg</th>
            <td><strong>Täistööaeg ja tööle asumine KOHESELT</strong></td>
          </tr>
        </tbody>
      </table>
      <p class="job-contact">
        CV koos palgasooviga saata e-mailile:
        <a href={`mailto:${company.email}`}>{company.email}</a>
      </p>
    </article>

    <article class="job-card">
      <h2>ISOLEERIJA</h2>
      <table>
        <tbody>
          <tr>
            <th scope="row">Pakutav töökoht</th>
            <td><strong>ISOLEERIJA</strong></td>
          </tr>
          <tr>
            <th scope="row">Tööpakkumine aegub</th>
            <td><strong>Lõppenud</strong></td>
          </tr>
          <tr>
            <th scope="row">Positsioon</th>
            <td>oskustööline</td>
          </tr>
          <tr>
            <th scope="row">Töökoht asub</th>
            <td>Harjumaa, Tallinn, Eesti</td>
          </tr>
          <tr>
            <th scope="row">Töökoha kirjeldus</th>
            <td>Ventilatsioonisüsteemide isoleerimine tööandja ehitusobjektidel Tallinnas ja mujal Eestis.</td>
          </tr>
          <tr>
            <th scope="row">Nõuded kandidaadile</th>
            <td>
              <p>Kandidaadilt ootame</p>
              <ul>
                <li>Eelnevat töökogemust</li>
                <li>Iseseisvust</li>
                <li>Vastutustunnet</li>
                <li>Otsustusvõimet</li>
              </ul>
              <p>Kasuks tuleb</p>
              <ul>
                <li>Eelnev töökogemus isoleerijana</li>
                <li>Projektilugemisoskus</li>
                <li>Autojuhilubade olemasolu</li>
                <li>Vene keele oskus</li>
              </ul>
            </td>
          </tr>
          <tr>
            <th scope="row">Nõutav haridus</th>
            <td>täpsustamata</td>
          </tr>
          <tr>
            <th scope="row">Keeleoskus</th>
            <td>eesti</td>
          </tr>
          <tr>
            <th scope="row">Juhiload</th>
            <td>B</td>
          </tr>
          <tr>
            <th scope="row">Muu info</th>
            <td>
              <p>Omalt poolt pakume</p>
              <ul>
                <li>Võimalust töötada nooruslikus ja positiivses meeskonnas</li>
                <li>Konkurentsivõimelist palka töölepingu alusel</li>
                <li>Mitmekülgset tööd ja arenemisvõimalusi</li>
                <li>Väljaõpet koha peal</li>
                <li>Tööks vajalikke vahendeid (tööriistad ja rõivad)</li>
                <li>Sõidukit tööülesannete täitmiseks (B-kategooria)</li>
              </ul>
            </td>
          </tr>
          <tr>
            <th scope="row">Pakutav tööliik ja kuupalk</th>
            <td>kokkuleppel</td>
          </tr>
          <tr>
            <th scope="row">Tööaeg</th>
            <td>Täistööaeg</td>
          </tr>
        </tbody>
      </table>
      <p class="job-contact">
        CV koos palgasooviga saata e-mailile:
        <a href={`mailto:${company.email}`}>{company.email}</a>
      </p>
    </article>
  </section>
</BaseLayout>

<style>
  .jobs {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto 5rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
  }

  .job-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(7, 33, 63, 0.05);
  }

  .job-card h2 {
    margin: 0;
    padding: 1rem;
    color: var(--ink);
    font-size: clamp(1.05rem, 1.3vw, 1.25rem);
    text-align: center;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  tr {
    background: #f4f4f4;
    border-top: 1px solid #fff;
  }

  th,
  td {
    padding: 0.72rem 0.8rem;
    text-align: left;
    vertical-align: top;
    font-size: 0.94rem;
    line-height: 1.45;
  }

  th {
    width: 34%;
    color: var(--ink);
    font-weight: 800;
  }

  td {
    color: var(--ink);
  }

  td p {
    color: var(--ink);
    margin: 0 0 0.4rem;
  }

  td p:not(:first-child) {
    margin-top: 0.65rem;
  }

  ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .job-contact {
    padding: 1rem;
    color: var(--ink);
    border-top: 1px solid var(--line);
    background: #fff;
  }

  .job-contact a {
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .jobs {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    th,
    td {
      display: block;
      width: 100%;
    }

    th {
      padding-bottom: 0.2rem;
    }

    td {
      padding-top: 0.2rem;
    }
  }
</style>
